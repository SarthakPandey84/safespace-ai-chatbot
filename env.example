# ==============================================================================
# FILE: .env.example
# PURPOSE: Template for environment variables.
#
# INSTRUCTIONS:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your actual values in the .env file.
#   3. NEVER commit .env to version control — it is already in .gitignore.
#
# ACADEMIC NOTE — 12-Factor App:
#   Secrets must never be hardcoded in source code or committed to git.
#   See: https://12factor.net/config
# ==============================================================================

# Groq API Key — get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# (Optional) PostgreSQL URL for cloud deployment on Render/Supabase.
# Leave blank to use the default local SQLite database.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
